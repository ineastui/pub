{
  "permissions": {
    "allow": [
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git remote *)",
      "Bash(git config *)",
      "Bash(gh auth *)",
      "Bash(cmdkey /list)",
      "Bash(powershell.exe -Command \"Get-StoredCredential -Target 'git:https://github.com' 2>/dev/null\")",
      "Bash(powershell.exe -Command '[System.Net.ServicePointManager]::SecurityProtocol; $cred = cmdkey /list; $cred')",
      "Bash(cmdkey.exe /list)",
      "Bash(cmdkey.exe /delete:git:https://github.com)",
      "Bash(cmdkey.exe /delete:\"GitHub - https://api.github.com/ddeock\")",
      "Bash(powershell.exe *)"
    ]
  }
}
